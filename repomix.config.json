{
  "output": {
    "style": "xml",
    "removeComments": true,
    "removeEmptyLines": true,
    "compress": true,
    "filePath": "flutter-devcontainer-code.xml"
  },
  "include": [
    "**/*",
    ".github/**/*"
  ],
  "security": {
    "enableSecurityCheck": false
  },
  "ignore": {
    "useGitignore": false,
    "useDefaultPatterns": false,
    "customPatterns": [
      ".git",
      "node_modules",
      ".venv",
      "__pycache__",
      "*.pyc",
      "dist",
      "build",
      "*.log",
      ".env",
      "package-lock.json",
      "flutter-template-code.xml",
      "repomix.config.json"
    ]
  }
}